{
  "name": "codex-gui",
  "version": "1.0.0",
  "description": "GUI wrapper for Codex CLI — terminal for people who don't like terminals",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "simple-git": "^3.19.1",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.8.0",
    "@xterm/addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.4",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codex-gui.app",
    "productName": "Codex GUI",
    "files": ["dist/**/*", "main.js", "preload.js"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
